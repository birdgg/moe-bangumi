packages:
  .
  vendor/effectful-sqlite
  vendor/bgmtv-hs
  vendor/qbittorrent-hs

with-compiler: ghc-9.14.1

allow-newer:
  *:base,
  *:template-haskell,
  *:ghc-prim,
  *:text,
  *:containers,
  *:bytestring,
  *:time,
  *:http-api-data

tests: False
benchmarks: False
split-sections: True
executable-stripping: True
library-stripping: True

package *
  tests: False
  benchmarks: False
